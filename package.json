{
  "name": "repo-assistant",
  "version": "1.0.0",
  "private": true,
  "description": "an ai assistant for your repo",
  "author": "guillermoscript",
  "license": "ISC",
  "homepage": "https://github.com/",
  "keywords": [
    "probot",
    "github",
    "probot-app"
  ],
  "scripts": {
    "build": "tsc",
    "build:action": "rm -rf dist && ncc build src/action.ts -o dist --source-map --minify --target es2022 && find dist -name '*.d.ts' -delete && find dist -type d -empty -delete",
    "start": "probot run ./lib/index.js",
    "test": "jest",
    "sync": "node ./lib/sync.js $user $repo",
    "auto-close": "node ./lib/autoClose.js"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.58",
    "@chat-adapter/github": "^4.27.0",
    "@chat-adapter/state-pg": "^4.27.0",
    "@neondatabase/serverless": "^1.1.0",
    "ai": "^6.0.174",
    "chat": "^4.27.0",
    "dotenv": "^17.4.2",
    "octokit": "^5.0.5",
    "probot": "^14.3.2",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@vercel/ncc": "^0.38.4",
    "jest": "^30.3.0",
    "nock": "^14.0.14",
    "smee-client": "^5.0.0",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3"
  }
}
