# ===== Probot / GitHub App =====
# GitHub App ID (numeric). From https://github.com/settings/apps/<your-app>
APP_ID=
# GitHub App private key. Use ONE of these two:
#   (a) PRIVATE_KEY_PATH points at a .pem file on disk (recommended for multi-line PEM)
#   (b) PRIVATE_KEY inlines the PEM, wrapped in double quotes with \n for newlines
PRIVATE_KEY_PATH=./your-app.private-key.pem
# PRIVATE_KEY=
# Webhook secret you set when creating the GitHub App
WEBHOOK_SECRET=development
# Smee proxy URL for local dev. Get one at https://smee.io/new
WEBHOOK_PROXY_URL=
# trace | debug | info | warn | error
LOG_LEVEL=debug

# ===== OpenAI (Vercel AI SDK provider) =====
# Required. https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Optional. Override default chat model (default: gpt-4o-mini)
OPENAI_CHAT_MODEL=
# Optional. Override default embedding model (default: text-embedding-3-small).
# Must produce 1536-dim vectors to match the `documents.embedding` column.
OPENAI_EMBEDDING_MODEL=

# ===== Postgres (Neon recommended; Supabase or any pgvector ≥0.8 also works) =====
# Single connection string used for vector search AND Chat SDK state.
# Neon: https://console.neon.tech → create project → copy "Connection string"
# Run db/schema.sql once on a fresh DB to bootstrap the documents table + RPC.
DATABASE_URL=

# ===== Sync script only — OPTIONAL =====
# Only needed if you run `npm run sync` to backfill existing issues into the DB.
# Not used by the running bot (the GitHub App handles auth via PRIVATE_KEY).
# Personal access token w/ repo scope. https://github.com/settings/tokens
# GITHUB_TOKEN=

# ===== Auto-close worker — OPTIONAL =====
# Closes confirmed duplicate issues after a grace period if no human override.
# In production this runs as a GitHub Actions cron (.github/workflows/auto-close.yml)
# using GITHUB_TOKEN. The variables below are only useful for local CLI runs.
# Defaults to OFF. Set to "true" to allow `npm run auto-close` to close issues.
# AUTO_CLOSE_ENABLED=false
# Comma-separated `owner/repo` list to scan when running locally.
# AUTO_CLOSE_REPOS=
# Hours after the bot adds the `duplicate` label before auto-close fires (default 72).
# AUTO_CLOSE_GRACE_HOURS=72
# Set true to log decisions without closing (recommended for first run).
# AUTO_CLOSE_DRY_RUN=true
# Optional. Override which user is considered the "bot" for label/comment attribution.
# Default behavior: any actor with type=Bot. Useful for testing or self-hosted setups.
# AUTO_CLOSE_BOT_LOGIN=

# ===== Chat SDK GitHub adapter — OPTIONAL =====
# Enables the conversational comment surface: @-mention commands like
# `@<bot> dup #123`, `@<bot> notdup`, `@<bot> quality`, `@<bot> relabel a,b,c`,
# plus free-form AI follow-ups. Off by default. When on, configure a SECOND
# webhook URL on your GitHub App pointing to /api/chat/github and subscribe
# to "Issue comments" events.
# CHAT_SDK_ENABLED=false
# Bot username used for @-mention detection (no @ prefix). For GitHub Apps use
# the app's bot login (e.g. "repo-assistant-ai[bot]").
# BOT_USERNAME=
# Chat SDK reuses DATABASE_URL above for state (subscriptions, locks, dedupe).
# GITHUB_TOKEN above is reused (PAT with `repo` scope) for adapter REST calls.
