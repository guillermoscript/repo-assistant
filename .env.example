# ===== Probot / GitHub App =====
# GitHub App ID (numeric). From https://github.com/settings/apps/<your-app>
APP_ID=
# GitHub App private key. Use ONE of these two:
#   (a) PRIVATE_KEY_PATH points at a .pem file on disk (recommended for multi-line PEM)
#   (b) PRIVATE_KEY inlines the PEM, wrapped in double quotes with \n for newlines
PRIVATE_KEY_PATH=./your-app.private-key.pem
# PRIVATE_KEY=
# Webhook secret you set when creating the GitHub App
WEBHOOK_SECRET=development
# Smee proxy URL for local dev. Get one at https://smee.io/new
WEBHOOK_PROXY_URL=
# trace | debug | info | warn | error
LOG_LEVEL=debug

# ===== OpenAI (Vercel AI SDK provider) =====
# Required. https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Optional. Override default chat model (default: gpt-4o-mini)
OPENAI_CHAT_MODEL=
# Optional. Override default embedding model (default: text-embedding-3-small).
# Must produce 1536-dim vectors to match the Supabase `documents.embedding` column.
OPENAI_EMBEDDING_MODEL=

# ===== Supabase =====
# https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ===== Sync script only — OPTIONAL =====
# Only needed if you run `npm run sync` to backfill existing issues into Supabase.
# Not used by the running bot (the GitHub App handles auth via PRIVATE_KEY).
# Personal access token w/ repo scope. https://github.com/settings/tokens
# GITHUB_TOKEN=
